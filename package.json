{
  "name": "youtubeshortdownloader",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env INIT_CWD=$PWD next dev --webpack",
    "start": "next dev --webpack",
    "contentlayer:build": "contentlayer2 build",
    "build": "yarn contentlayer:build && cross-env INIT_CWD=$PWD next build --webpack",
    "indexnow": "node ./scripts/submit-indexnow.mjs",
    "indexnow:dry": "node ./scripts/submit-indexnow.mjs --dry-run",
    "indexnow:verbose": "node ./scripts/submit-indexnow.mjs --verbose",
    "serve": "next start",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,mdx}\"",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "eslint --fix --ext .js,.jsx,.ts,.tsx app components lib layouts scripts",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "2.2.10",
    "@microsoft/clarity": "^1.0.2",
    "@next/bundle-analyzer": "16.2.4",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.12",
    "autoprefixer": "^10.4.13",
    "body-scroll-lock": "^4.0.0-beta.0",
    "cheerio": "^1.1.0",
    "contentlayer2": "0.5.8",
    "date-fns": "^4.1.0",
    "github-slugger": "^2.0.0",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.525.0",
    "next": "16.2.4",
    "next-contentlayer2": "0.5.8",
    "next-intl": "4.9.1",
    "next-themes": "0.4.6",
    "pliny": "0.4.1",
    "postcss": "^8.4.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.5.0",
    "react-share": "5.1.2",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-preset-minify": "7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-github-blockquote-alert": "^1.2.1",
    "remark-math": "^6.0.0",
    "soundcloud-downloader": "^1.0.0",
    "tailwindcss": "^3.4.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.0.1",
    "@types/mdx": "^2.0.12",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "cross-env": "^7.0.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^13.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "sharp": "^0.34.5",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@3.6.1"
}
